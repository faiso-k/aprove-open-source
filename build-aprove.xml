		<java classname="aprove.input.Programs.haskell.Translator" fork="yes" dir="${build}" failonerror="true" maxmemory="256m">
			<!--<arg line="${args}"/>-->
			<arg value="prelude" />
			<arg value="${haskellPreludeBigSerFile}" />
			<arg value="PRELUDE_BIG" />
			<classpath>
				<path refid="modulepath" />
				<pathelement location="${build}" />
			</classpath>
		</java>

		<java classname="aprove.input.Programs.haskell.Translator" fork="yes" dir="${build}" failonerror="true" maxmemory="256m">
