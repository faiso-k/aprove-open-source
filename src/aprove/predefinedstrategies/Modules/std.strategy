    defaults [Degree = 1
             ,Range = 1
             ,OPCSolver = NATTOFORMULA
             ,MaxSimpleDegree = -1
             ,StrictMode = AUTOSTRICTJAR
             ]

declare GPOLORAT = aprove.solver.GPOLORATFactory
    defaults [Degree = 1
             ,ExpMin = -1
             ,ExpMax = 1
             ,OPCSolver = RATTOFORMULA
             ,MaxSimpleDegree = -1
             ,StrictMode = ALLSTRICT
             ,Heuristic = FULLRAT
             ]

declare GPOLORATSIMPLE = aprove.solver.GPOLORATSIMPLEFactory
