
# This module is automatically included into the namespace of all strategy files parsed.
# Eventually, this will be automatically generated.
# For now, I've added vim folding markers, hoping they might be useful.
#
# For now, add processors and defaults manually.
# If the format isn't self-explanatory, kick BearPerson.


# Strategy infrastructure {{{1
# These two names are special, translated from : and ; respectively {{{2
declare Sequence = aprove.strategies.UserStrategies.Sequence
    defaults [Parallel = False]

declare ParallelSequence = aprove.strategies.UserStrategies.Sequence
    defaults [Parallel = True]

# These used to be keywords {{{2
declare First = aprove.strategies.UserStrategies.First
declare Any = aprove.strategies.UserStrategies.Any
declare AnyDelay = aprove.strategies.UserStrategies.AnyDelay
declare AnyK = aprove.strategies.UserStrategies.AnyK
declare Combine = aprove.strategies.UserStrategies.CombineSequential
declare CombineParallel = aprove.strategies.UserStrategies.CombineParallel
declare Delay = aprove.strategies.UserStrategies.Delay
declare Maybe = aprove.strategies.UserStrategies.Maybe
declare Timer = aprove.strategies.UserStrategies.Timer
declare WallTimer = aprove.strategies.UserStrategies.WallTimer
# TODO: Make these more elegant
declare Repeat = aprove.strategies.UserStrategies.Repeat
    defaults [Min=0, Max=-1, Breadth = True]

declare RepeatS = aprove.strategies.UserStrategies.Repeat
    defaults [Min=0, Max=-1, Breadth = False]

declare Solve = aprove.strategies.UserStrategies.Solve
    defaults [DesiredResult = WANT_ANY]

declare Prove = aprove.strategies.UserStrategies.Solve
    defaults [DesiredResult = WANT_YES]

declare Disprove = aprove.strategies.UserStrategies.Solve
    defaults [DesiredResult = WANT_NO]


# Processors {{{1
# General processor {{{2
declare External = aprove.verification.dpframework.ExternalProcessor
    defaults [Call = "", Args = ""]
declare ExternalTpdbTool = aprove.verification.dpframework.ExternalTpdbTool.ExternalTpdbToolProcessor

declare If = aprove.verification.dpframework.Heuristics.Processors.IfHeuristic


# Processor used for termination analyses {{{2
declare ConditionalTransformer = aprove.verification.oldframework.Rewriting.Transformers.ConditionalTransformer
declare CTRS2TRS = aprove.verification.oldframework.Rewriting.Transformers.ConditionalTransformer


# new QDPProcessor {{{2
declare QDPPairToRule = aprove.verification.dpframework.DPProblem.Processors.QDPPairToRuleProcessor
declare QDPDependencyGraph = aprove.verification.dpframework.DPProblem.Processors.DependencyGraphProcessor
declare QDPNonTerm = aprove.verification.dpframework.Heuristics.Processors.OldNonTermHeuristic
    defaults [TotalLimit = 3
             ,LeftLimit = 3
             ,RightLimit = 3
             ,Heuristic = NORMAL
             ]

declare QDPLoopFinder = aprove.verification.dpframework.DPProblem.Processors.NonTerminationProcessor
    defaults [TotalLimit = 3
             ,LeftLimit = 3
             ,RightLimit = 3
             ,Heuristic = NORMAL
             ]

declare QDPUsableRules = aprove.verification.dpframework.DPProblem.Processors.UsableRulesProcessor
    defaults [BeComplete = True, UseApplicativeCeRules = True]

declare QDPATransformation = aprove.verification.dpframework.DPProblem.Processors.ATransformationProcessor
    defaults [BeComplete = True, KeepMinimality = True]

declare QDPRRRQ = aprove.verification.dpframework.DPProblem.Processors.RRR_Q_Processor
declare QDPMatchbounds = aprove.verification.dpframework.DPProblem.Processors.RFCMatchBoundsProcessor
    defaults [NodeBound = 90, EdgeBound = 120]

declare QDPIntroMinimality = aprove.verification.dpframework.DPProblem.Processors.IntroMinimalityProcessor
declare QDPPolo = aprove.verification.dpframework.DPProblem.Processors.QDPPoloProcessor
    defaults [Degree = 1
             ,Range = 1
             ,Mode = SEARCHSTRICT
             ,MaxSimpleDegree = 4
             ,Active = True
             ,MergeMutual = True
             ,Engine = SAT4J
                 [AndMode = FLATTEN
                 ,OrMode = FLATTEN
                 ,Sharing = True
                 ,NodeLimit = -2
                 ]
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ]
             ,Simplification = MAXIMUM
             ,SimplifyAll = True
             ,StripExponents = False
             ]

declare QDPNegPolo = aprove.verification.dpframework.DPProblem.Processors.QDPNegPoloProcessor
    defaults [Range = 1, Restriction = 2, Allstrict = False]

declare QDPMNOC = aprove.verification.dpframework.DPProblem.Processors.MNOCProcessor
    defaults [TestDepth = 2, Reversed = False]

declare QDPUsableRulesRP = aprove.verification.dpframework.DPProblem.Processors.UsableRulesReductionPairsProcessor
    defaults [AllowATransformation = True
             ,Degree = 1
             ,Range = 2
             ,MaxSimpleDegree = 5
             ,Engine = SAT4J
                 [AndMode = FLATTEN
                 ,OrMode = FLATTEN
                 ,Sharing = True
                 ,NodeLimit = -2
                 ]
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ]
             ,Simplification = MAXIMUM
             ,SimplifyAll = True
             ,StripExponents = False
             ]

declare QDPRuleRemoval = aprove.verification.dpframework.DPProblem.Processors.RuleRemovalProcessor
    defaults [Degree = 1
             ,Range = 2
             ,Mode = SEARCHSTRICT
             ,MaxSimpleDegree = 5
             ,Engine = SAT4J
                 [AndMode = FLATTEN
                 ,OrMode = FLATTEN
                 ,Sharing = True
                 ,NodeLimit = -2
                 ]
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ]
             ,Simplification = MAXIMUM
             ,SimplifyAll = True
             ,StripExponents = False
             ]

declare QDPMRR = aprove.verification.dpframework.DPProblem.Processors.MRRProcessor
    defaults [Order = RPOS
                 [Engine = MINISAT, Quasi = True, Afstype = MONOTONEAFS]
             ,Allstrict = False
             ]

declare QDPQMonMRR = aprove.verification.dpframework.DPProblem.Processors.QDPQMonotonicMRRProcessor
    defaults [Order = POLO
                 [Engine = MINISAT, Range = 2]
             ,DeleteROnly = True
             ]

declare QDPAfsSolver = aprove.verification.dpframework.DPProblem.Processors.QDPAfsSolverProcessor
declare QDPSATAfsSolver = aprove.verification.dpframework.DPProblem.Processors.QDPSATAfsSolverProcessor
    defaults [Order = LPO[Quasi = False], Active = True]

declare QDPSizeChange = aprove.verification.dpframework.DPProblem.Processors.QDPSizeChangeProcessor
    defaults [Subterm = False
             ,UsableArgumentsRestriction = 0
             ,AfsRestriction = 2
             ,MergeMutual = True
             ,Range = 1
             ,Engine = SAT4J
             ]

declare QDPQReduction = aprove.verification.dpframework.DPProblem.Processors.QDPQReductionProcessor
    defaults [KeepMinimality = True]

declare QDPInstantiation = aprove.verification.dpframework.DPProblem.Processors.QDPInstantiationProcessor
    defaults [Limit = 0]

declare QDPForwardInstantiation = aprove.verification.dpframework.DPProblem.Processors.QDPForwardInstantiationProcessor
    defaults [Limit = 0]

declare QDPRewriting = aprove.verification.dpframework.DPProblem.Processors.QDPRewritingProcessor
    defaults [Limit = 50, BeComplete = False]

declare QDPNarrowing = aprove.verification.dpframework.DPProblem.Processors.QDPNarrowingProcessor
    defaults [Limit = 0
             ,BeComplete = False
             ,Positional = True
             ,NonrecursiveHeuristic = True
             ]

declare QDPSemanticLabelling = aprove.verification.dpframework.DPProblem.Processors.SemanticLabellingProcessor
    defaults [CarrierSetSize = 2
             ,AllowQuasi = True
             ,Engine = SAT4J
             ,BooleanTuples = False
             ,Dimension = 2
             ,IncrementalEngine = INCREMENTAL
             ,EnforceQuasi = False
             ]

declare QDPRootLabelingFC1 = aprove.verification.dpframework.DPProblem.Processors.QDPRootLabelingFC1Processor
    defaults [Heuristic = LabelAll
             ,PreserveMinimality = True
             ]

declare QDPRootLabelingFC2 = aprove.verification.dpframework.DPProblem.Processors.QDPRootLabelingFC2Processor
    defaults [Heuristic = LabelAll
             ,PreserveMinimality = True
             ]

declare QDPToSRS = aprove.verification.dpframework.DPProblem.Processors.QDPToSRSProcessor
    defaults [Zantema = True]

declare QDPBoundedIncrease = aprove.verification.dpframework.DPProblem.Processors.QDPBoundedIncreaseProcessor
declare QDPReductionPair = aprove.verification.dpframework.DPProblem.Processors.QDPReductionPairProcessor
    defaults [Heuristic = FullSearch
             ,Order = POLO
                 [Engine = MINISAT[Version = 2], Degree = 1, Range = 2]
             ,Allstrict = False
             ,Active = True
             ,MergeMutual = True
             ,Usable = True
             ]

declare QDPNegCoeffPolo = aprove.verification.dpframework.DPProblem.Processors.QDPNegCoeffPoloProcessor
    defaults [PosRange = 1
             ,NegRange = -1
             ,Usable = True
             ,Active = False
             ,Heuristic = PRHS
             ,Simplification = MAXIMUM
             ,StripExponents = True
             ,Engine = MINISAT
                 [Version = 2
                 ,AndMode = FLATTEN
                 ,OrMode = FLATTEN
                 ,Sharing = True
                 ,NodeLimit = -2
                 ]
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ,AppendForTimes = True
                 ,Tracking = True
                 ,ProductAbstraction = False
                 ]
             ]

declare QDPFuncArityProc = aprove.verification.dpframework.DPProblem.Processors.QDPFuncArityProcessor
declare QDPAddDPConstraints = aprove.verification.dpframework.DPProblem.Processors.QDPAddDPConstraintsProcessor
    defaults [LeftChainCounter = 0
             ,RightChainCounter = 1
             ,InductionCounter = 3
             ]

declare QDPNonMonReductionPair = aprove.verification.dpframework.DPProblem.Processors.QDPNonMonReductionPairProcessor
    defaults [Allstrict = False
             ,PosRange = 1
             ,NegRange = -1
             ,Heuristic = CAND1
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ]
             ,Engine = MINISAT[Version = 1]
             ]

declare QDPNonInfReductionPair = aprove.verification.dpframework.DPProblem.Processors.QDPNonInfReductionPairProcessor
    defaults [Engine = MINISAT[Version = 2]
             ,DegreeTuple = 1
             ,Maximum = 1
             ,MaximumForSmall = 1
             ,Minimum = 1
             ,LeftChainCounter = 0
             ,RightChainCounter = 1
             ,InductionCounter = 3
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ]
             ,EnforceNegative = False
             ,DetectNonNegative = False
             ]

declare QDPnonInfMoreInductionCheck = aprove.verification.dpframework.DPProblem.Processors.QDPNonInfMoreInductionCheckProcessor
declare QDPComplexConstantRemoval = aprove.verification.dpframework.DPProblem.Processors.QDPComplexConstantRemovalProcessor
declare QDPSemanticPOLOLabelling = aprove.verification.dpframework.DPProblem.Processors.QDPSemanticPOLOLabellingProcessor
declare QDPSubterm = aprove.verification.dpframework.DPProblem.Processors.QDPSubtermProcessor
    defaults [Engine = SAT4J, Allstrict = False]

declare QDPTheoremProver = aprove.verification.dpframework.DPProblem.Processors.QDPTheoremProverProcessor
    defaults [Order = POLO[Engine = SAT4J, Range = 1, Degree = 1]
             ,TheoremProverStrategy = "thm"
             ,UnpackConstructors = True
             ,RemoveDuplicates = True
             ]

declare QDPUncurrying = aprove.verification.dpframework.DPProblem.Processors.QDPUncurryingProcessor
    defaults [Method = HIRO_MIDDEL_ZANKL, Top = False]
declare QDPNonLoop = aprove.verification.dpframework.DPProblem.Processors.QDPNonLoopProcessor
declare QDPStandardRepresentation = aprove.verification.dpframework.DPProblem.Processors.QDPStandardRepresentationProcessor
declare QDPBoundsTAProcessor = aprove.verification.dpframework.DPProblem.Processors.QDPBoundsTAProcessor
    defaults [STAS = OSFEFS, CRS = KMS]

declare QDPDumpChains = aprove.verification.dpframework.DPProblem.Processors.QDPDumpChainsProcessor
    defaults [MaxPSteps = 10, MaxRSteps=10]

