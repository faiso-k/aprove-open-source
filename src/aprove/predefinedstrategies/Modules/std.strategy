# More orders {{{2
declare MATRO = aprove.solver.MATROFactory
    defaults [Engine = MINISAT
                 [Version = 2
                 ,AndMode = FLATTEN
                 ,OrMode = LEFT_COMB
                 ,Sharing = True
                 ,NodeLimit = -2
                 ]
             ,Range = 1
             ,Type = COLLAPSINGDPTUPLE[Size = 2, Filter = NOFILTER]
             ,Linearity = LINEAR
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ,AppendForTimes = True
                 ,Tracking = True
                 ,ProductAbstraction = False
                 ]
             ,Simplification = CONTEXT_FREE
             ,SimplifyAll = True
             ,StripExponents = True
             ,DioLogic = False
             ,NewSearchStrict = False
             ,Rational = False
             ,Denominator = 1
             ]

