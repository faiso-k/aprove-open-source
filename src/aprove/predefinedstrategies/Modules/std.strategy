                 [AndMode = FLATTEN
                 ,OrMode = FLATTEN
                 ,Sharing = True
                 ,NodeLimit = -2
                 ]
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ,AppendForTimes = True
                 ,Tracking = True
                 ,ProductAbstraction = False
                 ]
             ]

