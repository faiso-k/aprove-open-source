declare Map = java.util.LinkedHashMap


# Orderings {{{2
declare POLO = aprove.solver.POLOFactory
    defaults [Degree = 1
             ,Range = 1
             ,Autostrict = False
             ,AutostrictJar = False
             ,LinearMonotone = False
             ,Engine = SAT4J
                 [AndMode = FLATTEN
                 ,OrMode = FLATTEN
                 ,Sharing = True
                 ,NodeLimit = -2
                 ]
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
                 ,UseIFFsInGT = True
                 ,NewTimes = True
                 ,AppendForTimes = True
                 ,Tracking = True
                 ,ProductAbstraction = False
                 ]
             ,Simplification = MAXIMUM
             ,SimplifyAll = True
             ,StripExponents = False
             ,MaxSimpleDegree = 4
             ,Restriction = 2
             ]

declare LPO = aprove.solver.LPOFactory
    defaults [Engine = SAT4J
             ,Quasi = False
             ,Breadth = False
             ,Restriction = 2
             ,Afstype = FULLAFS
             ]

declare LPOS = aprove.solver.LPOSFactory
    defaults [Engine = SAT4J
             ,Quasi = False
             ,Breadth = False
             ,Restriction = 2
             ,Afstype = FULLAFS
             ]

declare RPO = aprove.solver.RPOFactory
    defaults [Engine = SAT4J
             ,Quasi = False
             ,Breadth = False
             ,Restriction = 2
             ,Afstype = FULLAFS
             ]

declare RPOS = aprove.solver.RPOSFactory
    defaults [Engine = SAT4J
             ,Quasi = False
             ,Breadth = False
             ,Restriction = 2
             ,Afstype = FULLAFS
             ]

declare PPO = aprove.solver.ParameterizablePOFactory
    defaults [Engine = MINISAT
             ,Quasi = False
             ,Multiset = True
             ,Lex = True
             ,Permute = True
             ,Prec = True
             ,Xgengrc = True
