             ,NegRange = -1
             ,Simplification = MAXIMUM
             ,StripExponents = True
             ,Engine = SAT4J
                 [AndMode = FLATTEN
                 ,OrMode = FLATTEN
                 ,Sharing = True
                 ,NodeLimit = -2
                 ]
             ,SatConverter = PLAIN
                 [GTMode = DEEP
                 ,SumType = MINIMAL
                 ,PowersAsComb = False
